EKM1
# Minimal AZERTY layout (fr-FR)
code fr-FR
levels 3

# Number row (HID usages 0x1E - 0x27)
map 0x1E 0 0x00 0x26 0x0026  # 1 -> &
map 0x1E 1 0x21 0x31 0x0031
map 0x1E 2 0x00 0x7C 0x007C
map 0x1F 0 0x00 0x00 0x00E9  # 2 -> e acute
map 0x1F 1 0x22 0x32 0x0032
map 0x1F 2 0x00 0x7E 0x007E
map 0x20 0 0x00 0x22 0x0022  # 3 -> "
map 0x20 1 0x23 0x33 0x0033
map 0x20 2 0x00 0x23 0x0023
map 0x21 0 0x00 0x27 0x0027  # 4 -> '
map 0x21 1 0x24 0x34 0x0034
map 0x21 2 0x00 0x7B 0x007B
map 0x22 0 0x00 0x28 0x0028  # 5 -> (
map 0x22 1 0x25 0x35 0x0035
map 0x22 2 0x00 0x5B 0x005B
map 0x23 0 0x00 0x2D 0x002D  # 6 -> -
map 0x23 1 0x26 0x36 0x0036
map 0x23 2 0x00 0x7C 0x007C
map 0x24 0 0x00 0x00 0x00E8  # 7 -> e grave
map 0x24 1 0x27 0x37 0x0037
map 0x24 2 0x00 0x60 0x0060
map 0x25 0 0x53 0x5F 0x005F  # 8 -> _
map 0x25 1 0x28 0x38 0x0038
map 0x25 2 0x5A 0x5C 0x005C
map 0x26 0 0x00 0x00 0x00E7  # 9 -> c cedilla
map 0x26 1 0x29 0x39 0x0039
map 0x26 2 0x00 0x5E 0x005E
map 0x27 0 0x00 0x00 0x00E0  # 0 -> a grave
map 0x27 1 0x20 0x30 0x0030
map 0x27 2 0x5E 0x40 0x0040

# Row 1 (AZERTY on US QWERTY positions)
map 0x14 0 0x30 0x61 0x0061  # Q -> a
map 0x14 1 0x30 0x41 0x0041
map 0x1A 0 0x49 0x7A 0x007A  # W -> z
map 0x1A 1 0x49 0x5A 0x005A
map 0x08 0 0x34 0x65 0x0065  # E -> e
map 0x08 1 0x34 0x45 0x0045
map 0x08 2 0x00 0x00 0x20AC  # E AltGr -> euro
map 0x15 0 0x41 0x72 0x0072  # R -> r
map 0x15 1 0x41 0x52 0x0052
map 0x17 0 0x43 0x74 0x0074  # T -> t
map 0x17 1 0x43 0x54 0x0054
map 0x1C 0 0x48 0x79 0x0079  # Y -> y
map 0x1C 1 0x48 0x59 0x0059
map 0x18 0 0x44 0x75 0x0075  # U -> u
map 0x18 1 0x44 0x55 0x0055
map 0x0C 0 0x38 0x69 0x0069  # I -> i
map 0x0C 1 0x38 0x49 0x0049
map 0x12 0 0x3E 0x6F 0x006F  # O -> o
map 0x12 1 0x3E 0x4F 0x004F
map 0x13 0 0x3F 0x70 0x0070  # P -> p
map 0x13 1 0x3F 0x50 0x0050

# Row 2 (AZERTY on US ASDF...)
map 0x04 0 0x40 0x71 0x0071  # A -> q
map 0x04 1 0x40 0x51 0x0051
map 0x16 0 0x42 0x73 0x0073  # S -> s
map 0x16 1 0x42 0x53 0x0053
map 0x07 0 0x33 0x64 0x0064  # D -> d
map 0x07 1 0x33 0x44 0x0044
map 0x09 0 0x35 0x66 0x0066  # F -> f
map 0x09 1 0x35 0x46 0x0046
map 0x0A 0 0x36 0x67 0x0067  # G -> g
map 0x0A 1 0x36 0x47 0x0047
map 0x0B 0 0x37 0x68 0x0068  # H -> h
map 0x0B 1 0x37 0x48 0x0048
map 0x0D 0 0x39 0x6A 0x006A  # J -> j
map 0x0D 1 0x39 0x4A 0x004A
map 0x0E 0 0x3A 0x6B 0x006B  # K -> k
map 0x0E 1 0x3A 0x4B 0x004B
map 0x0F 0 0x3B 0x6C 0x006C  # L -> l
map 0x0F 1 0x3B 0x4C 0x004C
map 0x33 0 0x3C 0x6D 0x006D  # ; -> m
map 0x33 1 0x3C 0x4D 0x004D

# Row 3 (AZERTY on US ZXCV...)
map 0x1D 0 0x46 0x77 0x0077  # Z -> w
map 0x1D 1 0x46 0x57 0x0057
map 0x1B 0 0x47 0x78 0x0078  # X -> x
map 0x1B 1 0x47 0x58 0x0058
map 0x06 0 0x32 0x63 0x0063  # C -> c
map 0x06 1 0x32 0x43 0x0043
map 0x19 0 0x45 0x76 0x0076  # V -> v
map 0x19 1 0x45 0x56 0x0056
map 0x05 0 0x31 0x62 0x0062  # B -> b
map 0x05 1 0x31 0x42 0x0042
map 0x11 0 0x3D 0x6E 0x006E  # N -> n
map 0x11 1 0x3D 0x4E 0x004E

# Punctuation keys (HID usages 0x2D - 0x38)
map 0x2D 0 0x58 0x2D 0x002D  # - key
map 0x2D 1 0x53 0x5F 0x005F
map 0x2E 0 0x56 0x3D 0x003D  # = key
map 0x2E 1 0x57 0x2B 0x002B
map 0x36 0 0x52 0x2C 0x002C  # ,
map 0x36 1 0x5B 0x3F 0x003F
map 0x37 0 0x00 0x3B 0x003B  # ;
map 0x37 1 0x50 0x2E 0x002E
map 0x38 0 0x51 0x3A 0x003A  # :
map 0x38 1 0x59 0x2F 0x002F

# Space and Enter
map 0x2C 0 0x60 0x20 0x0020  # Space
map 0x2C 1 0x60 0x20 0x0020
map 0x28 0 0x61 0x0A 0x000A  # Enter
map 0x28 1 0x61 0x0A 0x000A
