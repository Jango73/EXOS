{
    "logs": [
        "log/kernel.log"
    ],
    "scriptsDir": ".",
    "keyBindings": {
        "C-e": { "label": "Setup Dependencies", "script": "1-1-setup-deps.sh" },
        "C-f": { "label": "Format Code", "script": "3-1-format-all-code.sh" },
        "C-h": { "label": "Build help", "script": "3-2-generate-kernel-docs.sh" },
        "C-w": { "label": "Start server", "script": "net/start-server.sh" },

        "i386-----------------": "",

        "f1": { "label": "Clean", "script": "make ARCH=i386 clean" },
        "f2": { "label": "Build MBR Release", "script": "scripts/build --arch i386 --fs ext2 --release" },
        "f3": { "label": "Build MBR Debug", "script": "scripts/build --arch i386 --fs ext2 --debug" },
        "f4": { "label": "Build MBR Debug Split", "script": "DEBUG_SPLIT=1 scripts/build --arch i386 --fs ext2 --debug" },
        "C-u": { "label": "Build UEFI Release", "script": "scripts/build --arch i386 --fs ext2 --release --uefi" },
        "C-i": { "label": "Build UEFI Debug", "script": "scripts/build --arch i386 --fs ext2 --debug --uefi" },

        "C-y": { "label": "Build System Data View", "script": "scripts/build --arch i386 --fs ext2 --system-data-view" },
        "C-v": { "label": "Build VESA Test Payload", "script": "make -C boot-hd PAYLOAD_SOURCE=test-payloads/vesa-test.c ARCH=i386 install-vbr-payload" },
        "C-d": { "label": "Build Dumper Payload", "script": "make -C boot-hd PAYLOAD_SOURCE=test-payloads/dumper*.c ARCH=i386 install-vbr-payload" },
        "C-k": { "label": "Build BIOS Keyboard Payload", "script": "make -C boot-hd PAYLOAD_SOURCE=test-payloads/bios-keyboard.c ARCH=i386 install-vbr-payload" },

        "f5": { "label": "Start QEMU", "script": "scripts/run --arch i386" },
        "f6": { "label": "Start QEMU + GDB", "script": "scripts/run --arch i386 --gdb" },
        "C-o": { "label": "Start QEMU UEFI", "script": "scripts/run --arch i386 --uefi" },
        "C-l": { "label": "Start QEMU UEFI + GDB", "script": "scripts/run --arch i386 --gdb --uefi" },

        "x86-64---------------": "",

        "f8": { "label": "Clean", "script": "make ARCH=x86-64 clean" },
        "f9": { "label": "Build MBR Release", "script": "scripts/build --arch x86-64 --fs ext2 --release" },
        "f10": { "label": "Build MBR Debug", "script": "scripts/build --arch x86-64 --fs ext2 --debug" },
        "C-b": { "label": "Build UEFI Release", "script": "scripts/build --arch x86-64 --fs ext2 --release --uefi" },
        "C-n": { "label": "Build UEFI Debug", "script": "scripts/build --arch x86-64 --fs ext2 --debug --uefi" },

        "f11": { "label": "Start QEMU", "script": "scripts/run --arch x86-64" },
        "f12": { "label": "Start QEMU + GDB", "script": "scripts/run --arch x86-64 --gdb" },
        "C-g": { "label": "Start QEMU UEFI", "script": "scripts/run --arch x86-64 --uefi" },
        "C-t": { "label": "Start QEMU UEFI + GDB", "script": "scripts/run --arch x86-64 --gdb --uefi" },

        "3--------------------": "",

        "p": { "label": "Git Pull", "script": "git pull" },
        "C-p": { "label": "Git Push", "script": "git push" },
        "s": { "label": "Git Status", "script": "git status" },
        "C-s": { "label": "Git Diff Staged", "script": "git diff --staged" }
    },
    "settings": {
        "enableCommandHistory": true,
        "persistLogs": true,
        "notifyOnExit": true,
        "renderThrottleMs": 50,
        "maxLogLines": 1000,
        "sidebarMinWidth" : 25
    },
    "events": {
        "onDashboardStart": [
            {
                "action": "killProcess",
                "parameters": [
                    "qemu-system-i386"
                ]
            },
            {
                "action": "killProcess",
                "parameters": [
                    "qemu-system-x86_64"
                ]
            }
        ],
        "beforeStartProcess": []
    }
}
