{
    "logs": [
        "log/kernel.log"
    ],
    "scriptsDir": ".",
    "keyBindings": {
        "f9": { "label": "Setup Dependencies", "script": "1-1-setup-deps.sh" },
        "f10": { "label": "Format Code", "script": "3-1-format-all-code.sh" },
        "f11": { "label": "Build help", "script": "3-2-generate-kernel-docs.sh" },
        "f12": { "label": "Start server", "script": "net/start-server.sh" },

        "x86-32-----------------": "",

        "C-a": { "label": "Clean", "script": "make ARCH=x86-32 clean" },
        "C-z": { "label": "Build MBR Release", "script": "scripts/build --arch x86-32 --fs ext2 --release" },
        "C-e": { "label": "Build MBR Debug", "script": "scripts/build --arch x86-32 --fs ext2 --debug" },
        "C-r": { "label": "Build MBR Debug Split", "script": "scripts/build --arch x86-32 --fs ext2 --debug --split" },
        "C-t": { "label": "Build UEFI Release", "script": "scripts/build --arch x86-32 --fs ext2 --release --uefi" },
        "C-y": { "label": "Build UEFI Debug", "script": "scripts/build --arch x86-32 --fs ext2 --debug --uefi" },
        "C-u": { "label": "Build UEFI Debug split", "script": "scripts/build --arch x86-32 --fs ext2 --debug --split --uefi" },

        "C-w": { "label": "Build System Data View", "script": "scripts/build --arch x86-32 --fs ext2 --system-data-view" },
        "C-x": { "label": "Build VESA Test Payload", "script": "make -C boot-hd PAYLOAD_SOURCE=test-payloads/vesa-test.c ARCH=x86-32 install-vbr-payload" },
        "C-c": { "label": "Build Dumper Payload", "script": "make -C boot-hd PAYLOAD_SOURCE=test-payloads/dumper*.c ARCH=x86-32 install-vbr-payload" },
        "C-v": { "label": "Build BIOS Keyboard Payload", "script": "make -C boot-hd PAYLOAD_SOURCE=test-payloads/bios-keyboard.c ARCH=x86-32 install-vbr-payload" },

        "f1": { "label": "Start QEMU", "script": "scripts/run --arch x86-32" },
        "f2": { "label": "Start QEMU + GDB", "script": "scripts/run --arch x86-32 --gdb" },
        "f3": { "label": "Start QEMU UEFI", "script": "scripts/run --arch x86-32 --uefi" },
        "f4": { "label": "Start QEMU UEFI + GDB", "script": "scripts/run --arch x86-32 --gdb --uefi" },

        "x86-64---------------": "",

        "C-q": { "label": "Clean", "script": "make ARCH=x86-64 clean" },
        "C-s": { "label": "Build MBR Release", "script": "scripts/build --arch x86-64 --fs ext2 --release" },
        "C-d": { "label": "Build MBR Debug", "script": "scripts/build --arch x86-64 --fs ext2 --debug" },
        "C-f": { "label": "Build MBR Debug Split", "script": "scripts/build --arch x86-64 --fs ext2 --debug --split" },
        "C-g": { "label": "Build UEFI Release", "script": "scripts/build --arch x86-64 --fs ext2 --release --uefi" },
        "C-h": { "label": "Build UEFI Debug UDP", "script": "scripts/build --arch x86-64 --fs ext2 --debug --uefi --use-log-udp --log-udp-source 10.0.2.15:18195 --log-udp-dest 10.0.2.2:18194" },
        "C-j": { "label": "Build UEFI Debug Split", "script": "scripts/build --arch x86-64 --fs ext2 --debug --split --uefi --boot-stage-markers" },

        "f5": { "label": "Start QEMU", "script": "scripts/run --arch x86-64" },
        "f6": { "label": "Start QEMU + GDB", "script": "scripts/run --arch x86-64 --gdb" },
        "f7": { "label": "Start QEMU UEFI", "script": "scripts/run --arch x86-64 --uefi" },
        "f8": { "label": "Start QEMU UEFI + GDB", "script": "scripts/run --arch x86-64 --gdb --uefi" },

        "3--------------------": "",

        "p": { "label": "Git Pull", "script": "git pull" },
        "S-p": { "label": "Git Push", "script": "git push" },
        "s": { "label": "Git Status", "script": "git status" },
        "S-s": { "label": "Git Diff Staged", "script": "git diff --staged" }
    },
    "settings": {
        "enableCommandHistory": true,
        "persistLogs": true,
        "notifyOnExit": true,
        "renderThrottleMs": 50,
        "maxLogLines": 1000,
        "sidebarMinWidth" : 25
    },
    "events": {
        "onDashboardStart": [
            {
                "action": "killProcess",
                "parameters": [
                    "qemu-system-i386"
                ]
            },
            {
                "action": "killProcess",
                "parameters": [
                    "qemu-system-x86-64"
                ]
            }
        ],
        "beforeStartProcess": []
    }
}
